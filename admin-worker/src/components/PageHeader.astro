---
interface Props {
  title: string;
  subtitle?: string;
  action?: { label: string; id: string; icon?: string };
}
const { title, subtitle, action } = Astro.props;
---

<header class="page-header">
  <div>
    <h1 class="page-title">{title}</h1>
    {subtitle && <p class="page-subtitle">{subtitle}</p>}
  </div>
  {action && (
    <button class="btn btn-primary" id={action.id}>
      {action.icon ?? '+'} {action.label}
    </button>
  )}
</header>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 32px 32px 0;
    flex-wrap: wrap;
  }
  .page-title {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    line-height: 1.2;
  }
  .page-subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 4px;
  }
</style>
